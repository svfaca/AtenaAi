# ==========================================
# CONFIGURAÇÃO DE AMBIENTE - AtenaAI Frontend
# ==========================================

# Backend API URL
# Deve apontar para o backend FastAPI rodando em desenvolvimento
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend URL para chamadas server-side
BACKEND_URL=http://localhost:8000

# Session Configuration
SESSION_COOKIE_NAME=atena_session
SESSION_TTL=86400000

# Authentication
JWT_SECRET=sua-chave-secreta-aqui

# Node Environment
NODE_ENV=development

# Analytics (opcional)
NEXT_PUBLIC_ANALYTICS_ID=

